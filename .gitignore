# ==========================================
# 1. 基础全局忽略 (根目录及所有子目录生效)
# ==========================================
.DS_Store
Thumbs.db
*.log
*.tmp
*.swp
.vscode/
.idea/
.ruff_cache/
/node_modules/
/.playwright-mcp/
/playwright-report/
/test-results/

# ==========================================
# 2. 前端项目忽略 (针对 web 目录)
# ==========================================
web/node_modules/
web/.pnpm-store/
web/.next/
web/out/
web/build/
web/dist/
web/coverage/
web/.cache/
web/*.tsbuildinfo
web/*.log
web/.DS_Store
web/
web/.env
web/.env.local
web/.env.*.local
!web/.env.example


# 前端环境变量（保护您的敏感配置）
web/.env
web/.env.local
web/.env.*.local
!web/.env.example

# ==========================================
# 3. 后端项目忽略 (针对 agent_api 目录)
# ==========================================
agent_api/venv/
agent_api/env/
agent_api/.venv/
agent_api/__pycache__/
agent_api/**/*.py[cod]
agent_api/**/*.py.class
agent_api/.pytest_cache/
agent_api/.coverage
agent_api/htmlcov/

# 数据库文件 (防止把本地测试数据传上去)
agent_api/*.db
agent_api/*.sqlite
agent_api/*.sqlite3

# 上传的媒体文件
agent_api/uploads/
agent_api/media/

# 后端环境变量
agent_api/.env
agent_api/.env.*
!agent_api/.env.example