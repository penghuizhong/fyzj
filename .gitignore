# ==========================================
# 1. 基础全局忽略 (根目录及所有子目录生效)
# ==========================================
.DS_Store
Thumbs.db
*.log
*.tmp
*.swp
.vscode/
.idea/
.ruff_cache/
node_modules
/playwright-report/
/test-results/

# ==========================================
# 2. 前端项目忽略 (针对 web 目录)
# ==========================================
web/node_modules/
web/.pnpm-store/
web/.next/
web/out/
web/build/
web/dist/
web/coverage/
web/.cache/
web/*.tsbuildinfo

# 前端环境变量（保护您的敏感配置）
web/.env
web/.env.local
web/.env.*.local
!web/.env.example

# ==========================================
# 3. 后端项目忽略 (针对 api 目录)
# ==========================================
api/venv/
api/env/
api/.venv/
api/__pycache__/
api/**/*.py[cod]
api/**/*.py.class
api/.pytest_cache/
api/.coverage
api/htmlcov/

# 数据库文件 (防止把本地测试数据传上去)
api/*.db
api/*.sqlite
api/*.sqlite3

# 上传的媒体文件
api/uploads/
api/media/

# 后端环境变量
api/.env
api/.env.*
!api/.env.example