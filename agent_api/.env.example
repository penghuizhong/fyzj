# ==============================================================================
# 方圆智版 Agent 服务 - 环境配置模板 (.env.example)
# 使用说明：复制此文件并重命名为 .env，然后替换为您真实的密钥和密码。
# ==============================================================================

# ── 1. 基础网络与运行配置 ──────────────────────────────────────────────────
HOST=0.0.0.0
# Agent 服务独立运行在 8001 端口
PORT=8001
LOG_LEVEL=INFO
# 开发时可改为 dev，启用自动热重载
MODE=production
GRACEFUL_SHUTDOWN_TIMEOUT=30

# ── 2. 核心大模型 API 密钥 ─────────────────────────────────────────────────
# 请填入您需要用到的大模型密钥 (由 config.yaml 统一调度)
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DASHSCOPE_API_KEY=your_dashscope_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# 提示词注入检测与安全防护
ENABLE_SAFEGUARD=true
# 链路追踪 (Langfuse)，如暂不需要可保持 false
LANGFUSE_TRACING=false

# ── 3. 基础设施：PostgreSQL (专属 AI 记忆与状态库) ─────────────────────────
# 注意：在 Docker 网络中，HOST 直接填入 compose.infra.yaml 中的容器名
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_database_password
# 严格隔离：只使用 fyzj 这个逻辑库
POSTGRES_DB=fyzj

# 库表前缀与应用名称
POSTGRES_APPLICATION_NAME=agent_service
TABLE_NAME_PREFIX=agent_server_

# 连接池优化 (针对 psycopg_pool 的并发控制)
POSTGRES_MIN_CONNECTIONS_PER_POOL=1
POSTGRES_MAX_CONNECTIONS_PER_POOL=5
POSTGRES_POOL_OPEN_TIMEOUT=30
POSTGRES_POOL_CLOSE_TIMEOUT=10
POSTGRES_POOL_MAX_IDLE_TIME=300

# ── 4. 基础设施：Redis 与 Celery (严格的 DB Index 隔离) ────────────────────
# Agent 的缓存限流使用 1 号库，坚决不碰 Business 的 0 号库
REDIS_URL=redis://redis:6379/1
REDIS_MAX_CONNECTIONS=50

# 异步任务队列：Broker 用 1 号库，结果回调存 2 号库
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
CELERY_WORKER_CONCURRENCY=4

# ── 5. 安全防护与鉴权 (RS256 无状态验签) ──────────────────────────────────
# Agent 是“验证机关”，只存公钥。
# 注意：多行 RSA 公钥在 .env 中必须转换为单行，换行符用 \n 替代
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nMIIBIjANBgkqhkiG9w0BAQEFAAOCAQ8A...\n-----END PUBLIC KEY-----"
JWT_ALGORITHM=RS256

AUTH_SECRET=

# 全局接口限流策略 (防止恶意刷 Token)
RATE_LIMIT_ENABLED=true
# 未携带 Token 的游客访问频率
RATE_LIMIT_ANONYMOUS=5/minute
# 携带合法 Token 的用户访问频率
RATE_LIMIT_AUTHENTICATED=50/minute